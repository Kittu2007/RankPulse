{
  "buildCommand": "pnpm --filter @workspace/rankpulse... build",
  "outputDirectory": "artifacts/rankpulse/dist/public",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
